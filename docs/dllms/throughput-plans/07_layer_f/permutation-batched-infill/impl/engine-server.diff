+// POST /infill_batch  (07_layer_f batched variant-sweep)
+//
+// request:  {"canvases": [str, ...] (each a canvas with mask-piece markers; 1..4),
+//            same masked infill knobs as /generate: "seed","steps","conf_threshold",
+//            "early_commit","temp","top_k","top_p","eps","algorithm","backend_sampling"}
+// response: {"results": [{"text","steps_done","degenerate","n_prompt_tokens"}, ...],
+//            "ms_total": float (shared batched wall), "family": "masked"}
+static json handle_infill_batch(server_state & st, server_replica & rep, const json & req) {
+    if (st.canvas_length > 0 || st.block_ar) {
+        throw std::runtime_error("infill_batch requires a masked diffusion model");
+    }
+    if (!req.contains("canvases") || !req["canvases"].is_array() || req["canvases"].empty()) {
+        throw std::runtime_error("infill_batch requires a non-empty \"canvases\" array");
+    }
+    const json &  arr  = req["canvases"];
+    const int32_t N    = (int32_t) arr.size();
+    const int32_t n_ub = (int32_t) st.params.n_ubatch;
+    if (N > 4) {
+        throw std::runtime_error("at most 4 canvases per infill_batch");
+    }
+
+    std::vector<std::vector<llama_token>> toks(N);
+    std::vector<std::vector<llama_token>> outs(N);
+    std::vector<const llama_token *>      inp(N);
+    std::vector<llama_token *>            outp(N);
+    std::vector<int32_t>                  n_input(N), n_generated(N, 0), steps(N, 0);
+    bool                                  degb[4] = { false, false, false, false };
+
+    for (int32_t i = 0; i < N; i++) {
+        const std::string canvas = arr[i].get<std::string>();
+        toks[i]    = common_tokenize(rep.vocab, canvas, /*add special*/ true, /*parse special*/ true);
+        n_input[i] = (int32_t) toks[i].size();
+        if (n_input[i] <= 0 || n_input[i] > n_ub) {
+            throw std::runtime_error("canvas empty or longer than n_ubatch");
+        }
+        inp[i] = toks[i].data();
+        outs[i].assign(n_input[i], 0);
+        outp[i] = outs[i].data();
+    }
+
+    diffusion_params dp = make_masked_params(st, req);
+    dp.infill             = true;
+    dp.output_confidences = nullptr;
+
+    const int64_t t0 = ggml_time_us();
+    diffusion_generate_infill_batch(rep.ctx, inp.data(), outp.data(), n_input.data(), N, dp,
+                                    n_generated.data(), steps.data(), degb);
+    const double ms = (ggml_time_us() - t0) / 1000.0;
+
+    json results = json::array();
+    for (int32_t i = 0; i < N; i++) {
+        const int32_t ng = n_generated[i] > 0 ? n_generated[i] : n_input[i];
+        outs[i].resize(ng);
+        json r;
+        r["text"]            = common_detokenize(rep.vocab, outs[i], false);
+        r["steps_done"]      = steps[i];
+        r["degenerate"]      = degb[i];
+        r["n_prompt_tokens"] = n_input[i];
+        results.push_back(r);
+    }
+
+    json out;
+    out["results"]  = results;
+    out["ms_total"] = ms;
+    out["family"]   = "masked";
+    return out;
+}
