   defp forge_wrapper(_opts),
     do: "Write Elixir code for the following task. Reply with ONLY a single ```elixir code block, no explanation.\n\nTask: "
 
+  # G9 scaffold-seed (experiment, opt-in via opts["scaffold"]): build the module + function
+  # skeleton from the check so the model only diffuses the body. Returns nil to fall back to
+  # free-form drafting (no scaffold flag, no check, or an unparseable check).
+  defp scaffold_canvas(flag, check, mask) when flag in [true, "true"] and is_binary(check) do
+    case Regex.run(~r/\b([A-Z]\w*)\.(\w+[?!]?)\((.*)/, check) do
+      [_, mod, fname, rest] ->
+        args = Enum.take(~w(a b c d e), max(scaffold_arity(rest), 1)) |> Enum.join(", ")
+        "defmodule #{mod} do\n  def #{fname}(#{args}) do\n    #{String.duplicate(mask, 24)}\n  end\nend"
+
+      _ ->
+        nil
+    end
+  end
+
+  defp scaffold_canvas(_flag, _check, _mask), do: nil
+
+  # count top-level (depth-1) comma-separated args up to the call's closing paren
+  defp scaffold_arity(rest) do
+    {n, any} =
+      rest
+      |> String.to_charlist()
+      |> Enum.reduce_while({0, 1, false}, fn ch, {n, d, any} ->
+        cond do
+          ch in [?(, ?[, ?{] -> {:cont, {n, d + 1, any}}
+          ch in [?), ?], ?}] -> if d - 1 == 0, do: {:halt, {n, 0, any}}, else: {:cont, {n, d - 1, any}}
+          ch == ?, and d == 1 -> {:cont, {n + 1, d, true}}
+          ch in [?\s, ?\t] -> {:cont, {n, d, any}}
+          true -> {:cont, {n, d, true}}
+        end
+      end)
+      |> case do
+        {n, _d, any} -> {n, any}
+      end
+
+    if any, do: n + 1, else: 0
+  end
+
